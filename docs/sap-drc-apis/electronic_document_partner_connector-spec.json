  "paths" : {
    "/v2/destinations/{uuid}" : {
      "put" : {
        "tags" : [ "Destinations" ],
        "summary" : "Changes a destination.",
        "description" : "Changes one destination. After you proceed with this operation, the system returns the change status and the changed destination.",
        "operationId" : "updateDestinationV2",
        "parameters" : [ {
          "name" : "uuid",
          "in" : "path",
          "description" : "Unique identifier of the destination",
          "required" : true,
          "schema" : {
            "pattern" : "([a-f0-9]{8}(-[a-f0-9]{4}){4}[a-f0-9]{8})",
            "type" : "string",
            "example" : "73e4eb38-ea2c-48c0-95c3-4dd4f3d843a3"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/DestinationRequestV2"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "The destination was changed.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/DestinationResponseV2"
                }
              }
            }
          },
          "400" : {
            "description" : "Invalid data was supplied for the operation.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ExceptionMessagesResponse"
                }
              },
              "text/plain" : {
                "schema" : {
                  "type" : "string",
                  "example" : "Invalid UUID string: {UUID}"
                }
              }
            }
          },
          "404" : {
            "description" : "The destination was not found.",
            "content" : {
              "text/plain" : {
                "schema" : {
                  "type" : "string",
                  "example" : "The destination UUID does not exist: {UUID}"
                }
              }
            }
          },
          "409" : {
            "description" : "A destination with the same identifiers already exists.",
            "content" : {
              "text/plain" : {
                "schema" : {
                  "type" : "string",
                  "example" : "An entry already exists with the same key."
                }
              }
            }
          }
        },
        "security" : [ {
          "OAuth2" : [ ]
        } ]
      },
