          },
          "environmentType" : {
            "type" : "string",
            "description" : "Environment type for which the destination is used",
            "example" : "1",
            "enum" : [ "1", "2" ]
          },
          "documentModel" : {
            "maxLength" : 2,
            "minLength" : 2,
            "type" : "string",
            "description" : "Document model for which the destination is used",
            "example" : "00"
          },
          "state" : {
            "maxLength" : 2,
            "type" : "string",
            "description" : "State for which the destination is used, or empty if valid for any state",
            "example" : "RS"
          },
          "cityCode" : {
            "maxLength" : 10,
            "type" : "string",
            "description" : "City code for which the destination is used, or empty if valid for any city code",
            "example" : "4318705"
          },
          "action" : {
            "type" : "string",
            "description" : "Action in which the destination is used, or empty if valid for any action",
            "example" : "AUTHORIZE",
            "enum" : [ "AUTHORIZE", "CANCEL", "STATUS" ]
