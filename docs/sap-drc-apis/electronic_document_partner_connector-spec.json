    {
      "url": "https://sandbox.api.sap.com/DocumentReportingComplianceInvoicing4Brazil/electronic-document-partner-connector",
      "description": "Sandbox URL",
      "variables": {}
    },
    {
      "url": "https://nfe.cfapps.br10.hana.ondemand.com/electronic-document-partner-connector",
      "description": "Production URL",
