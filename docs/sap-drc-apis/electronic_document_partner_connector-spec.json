  "info" : {
    "title" : "Electronic Document Partner Connector",
    "description" : "Allows you to configure destinations in the cloud. Destinations are the elements that establish the connection between your cloud environment and SAP Document Compliance, outbound invoicing option for Brazil. Your cloud environment then communicates with the local authorities to send and receive the electronic documents. This API communicates with the *Manage Partner Destinations* screen (transaction NFE_CLOUD_DEST) of your source system.",
    "version" : "1.0.0"
  },
  "externalDocs" : {
    "description" : "Partner Enablement for SAP Document Compliance, outbound invoicing option for Brazil",
    "url" : "https://help.sap.com/viewer/71b3b178e5cb4a50a88cf2985a14f17c/Cloud/en-US/8f203794372d413eae6da083e5e0838f.html"
  },
  "x-sap-shortText": "Enables the configuration of destinations in the cloud.",
