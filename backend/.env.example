# ============================================================
# DFeAxis Backend — Environment Variables
# Copy to .env and fill in the values
# ============================================================

# --- Supabase (required) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sbp_...
SUPABASE_ANON_KEY=eyJhbGc...

# --- Encryption (required) ---
# 32+ character random string. Generate with: openssl rand -hex 32
CERT_MASTER_SECRET=CHANGE_ME_32_CHARS_MIN

# --- SEFAZ Environment (required) ---
# 1 = Produção, 2 = Homologação
# NEVER use 1 for testing
SEFAZ_AMBIENTE=2

# --- Environment ---
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://www.dfeaxis.com.br

# --- Stripe (required for billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CHECKOUT_SUCCESS_URL=https://www.dfeaxis.com.br/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://www.dfeaxis.com.br/financeiro/creditos
STRIPE_PORTAL_RETURN_URL=https://www.dfeaxis.com.br/dashboard

# --- Resend (email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@dfeaxis.com.br

# --- Rate limiting (optional, defaults in config.py) ---
RATE_LIMIT_AUTH=20
RATE_LIMIT_SEFAZ=30
RATE_LIMIT_READ=100

# --- Allowed hosts (production only) ---
ALLOWED_HOSTS=dfeaxis.com.br,www.dfeaxis.com.br,dfeaxis-production.up.railway.app

# --- Logging ---
LOG_LEVEL=INFO
