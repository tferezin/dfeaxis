# Supabase (formato novo: sb_publishable_* / sb_secret_*)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Security
CERT_MASTER_SECRET=change-me-to-a-random-256-bit-secret
JWT_SECRET=
ALLOWED_HOSTS=api.dfeaxis.com.br

# Stripe billing
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/financeiro/creditos
ALLOWED_REDIRECT_HOSTS=dfeaxis.com.br,www.dfeaxis.com.br,localhost:3000

# Anthropic (chat bot)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Admin (allowlist de e-mails que tem acesso ao painel admin)
ADMIN_EMAILS=admin@dfeaxis.com.br
PROD_ACCESS_ALLOWED=

# Resend (transactional email)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=DFeAxis <noreply@dfeaxis.com.br>
SUPPORT_EMAIL=suporte@dfeaxis.com.br

# GA4 server-side (Measurement Protocol)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=

# SEFAZ
SEFAZ_AMBIENTE=2

# App
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=20
RATE_LIMIT_SEFAZ=30

# Feature flags
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
