# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Security
CERT_MASTER_SECRET=change-me-to-a-random-256-bit-secret
JWT_SECRET=
ALLOWED_HOSTS=api.dfeaxis.com.br

# MercadoPago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# SEFAZ
SEFAZ_AMBIENTE=2

# App
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=20
RATE_LIMIT_SEFAZ=30

# Feature flags
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
